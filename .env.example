# Polymarket 
POLYMARKET_PK=                  # Ethereum private key (L1 auth)
POLYMARKET_API_KEY=             # L2 API key
POLYMARKET_API_SECRET=          # L2 API secret
POLYMARKET_API_PASSPHRASE=      # L2 passphrase
POLYMARKET_CHAIN_ID=137         # 137=Polygon, 80002=Amoy testnet
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# LLM — set ONE of the following (priority: Anthropic > DeepSeek > OpenAI)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=         # https://platform.deepseek.com — cheaper, OpenAI-compatible
OPENAI_API_KEY=

# Information retrieval
TAVILY_API_KEY=
NEWSAPI_KEY=

# Storage
DATA_DIR=./data
LOG_LEVEL=INFO
